# .gitignore - Uber ETL Pipeline (Apache Airflow)

# ============================================
# Virtual Environment
# ============================================
venv/
env/
ENV/
.env
.venv/

# ============================================
# Python Cache & Build
# ============================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
*.egg-info/
*.egg
*.manifest
*.spec

# ============================================
# Airflow
# ============================================
airflow.db
airflow.cfg
webserver_config.py
logs/
plugins/
*.pid
airflow-webserver.pid
airflow-scheduler.pid
airflow-worker.pid
airflow-webserver.log
airflow-scheduler.log
airflow-worker.log

# Airflow metadata database
airflow.db-journal
airflow.db-wal
airflow.db-shm

# ============================================
# Docker
# ============================================
.docker/
docker-compose.override.yml
*.dockerignore

# ============================================
# DuckDB
