# ============================================================================
# UBER ETL PIPELINE - .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
*.pyd
*.pyo
.pytest_cache/
.coverage
htmlcov/
.tox/

# ----------------------------------------------------------------------------
# Virtual Environment
# ----------------------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
.venv.bak/
virtualenv/

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
*.iml
.project
.classpath
.settings/
*.code-workspace

# ----------------------------------------------------------------------------
# Mage AI
# ----------------------------------------------------------------------------
mage_project/**/__pycache__/
mage_project/**/*.pyc
mage_project/.cache/
mage_project/logs/
mage_project/*.log
mage_project/**/.DS_Store

# ----------------------------------------------------------------------------
# DuckDB Database
# ----------------------------------------------------------------------------
warehouse/*.duckdb
warehouse/*.duckdb.wal
warehouse/*.db
warehouse/*.db.wal
warehouse/*.log
!warehouse/.gitkeep

# ----------------------------------------------------------------------------
# Data Files
# ----------------------------------------------------------------------------
data/*.csv
data/*.parquet
data/*.json
data/*.db
!data/uber_data.csv
!data/.gitkeep

# ----------------------------------------------------------------------------
# Streamlit
# ----------------------------------------------------------------------------
.streamlit/
*.streamlit/
.streamlitsecrets.toml

# ----------------------------------------------------------------------------
# Verification Reports (Auto-generated)
# ----------------------------------------------------------------------------
phase*_verification.json
phase*_verification_report.txt

# ----------------------------------------------------------------------------
# Verification Scripts (Local only)
# ----------------------------------------------------------------------------
verify-phase-*.py

# ----------------------------------------------------------------------------
# Temporary & Log Files
# ----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.backup
*.cache
*.temp
*.swp
notepad.txt
Complete*.txt
Verification*.md
*.aux
*.out
*.toc

# ----------------------------------------------------------------------------
# Local Configuration
# ----------------------------------------------------------------------------
local_files/
*.local
*.secret
config.local.*
*.user
*.private

# ----------------------------------------------------------------------------
# Jupyter Notebooks
# ----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb
*.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.*.secret
*.env
credentials.json
secrets.json

# ----------------------------------------------------------------------------
# Compressed Files
# ----------------------------------------------------------------------------
*.zip
*.tar.gz
*.rar
*.7z
*.gz
*.bz2
*.xz
*.tgz

# ----------------------------------------------------------------------------
# Node.js / JavaScript
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------
*.pid
*.pid.lock
.dockerignore
docker-compose.override.yml

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
*.pytest_cache/
test-results/

# ----------------------------------------------------------------------------
# OS Specific
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.dll
*.exe
*.so
*.dylib
$RECYCLE.BIN/
System Volume Information/

# ----------------------------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------------------------
*.sass-cache
*.scssc
*.cache
*.lock
*.pid
*.seed
*.pid.lock
*.sock
*.socket
*.swp
*.swo
*~
